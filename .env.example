TELEGRAM_BOT_TOKEN=
ALLOWED_CHAT_ID=

# ── Gateway de LLM (Bifrost) ──
# O Agent SDK aponta para o gateway (GATEWAY_URL), que roteia para o provedor do perfil
# ativo (Settings → Provedores de LLM) pelo nome do modelo (provider/modelo). As chaves
# abaixo são consumidas pelo gateway Bifrost.
GATEWAY_URL=http://localhost:8080/anthropic
# OpenAI: usada pelo gateway (modelos GPT) e pela transcrição de voz (Whisper).
OPENAI_API_KEY=
# z.ai (GLM):
ZAI_API_KEY=
# Sakana AI (Fugu):
SAKANA_API_KEY=
# Anthropic via gateway — separada de ANTHROPIC_API_KEY p/ não substituir a subscription do Claude:
BIFROST_ANTHROPIC_API_KEY=
# Opcional: virtual key do Bifrost (quando a governança está habilitada):
BIFROST_VIRTUAL_KEY=

AGENT_TIMEOUT_MS=0
MAX_OUTPUT_LENGTH=4096
DASHBOARD_TOKEN=
DASHBOARD_PORT=3000

# MySQL (required for Tracker feature)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=claudemar
MYSQL_PASSWORD=
MYSQL_DATABASE=claudemar

# Long-term memory (Qdrant + Voyage). Leave QDRANT_URL/VOYAGE_API_KEY empty to disable memory.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=claudemar_sessions
VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-4-large
EMBEDDING_DIM=1024
RERANK_MODEL=rerank-2.5
MEMORY_DOMAIN_INSTRUCTION=
RETRIEVE_CANDIDATES=40
RERANK_TOP_K=8
HYBRID_BM25=true
MEMORY_RECONCILE=false
